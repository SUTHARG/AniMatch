# ============================================================
#  AniMatch — Environment Variables Template
# ============================================================
# ─────────────────────────────────────────────
# Firebase — Web / Shared Configuration
# Get these from: Firebase Console → Project Settings → Your apps
# ─────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_WEB_APP_ID=1:your_sender_id:web:your_web_app_id

# ─────────────────────────────────────────────
# Firebase — Android Specific
# Get from: Project Settings → Android app → google-services.json
# ─────────────────────────────────────────────
FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_ANDROID_APP_ID=1:your_sender_id:android:your_android_app_id

# ─────────────────────────────────────────────
# Firebase — iOS / macOS Specific
# Get from: Project Settings → iOS app → GoogleService-Info.plist
# ─────────────────────────────────────────────
FIREBASE_IOS_API_KEY=your_ios_api_key_here
FIREBASE_IOS_APP_ID=1:your_sender_id:ios:your_ios_app_id
FIREBASE_IOS_CLIENT_ID=your_ios_client_id_here

# ─────────────────────────────────────────────
# Google Sign-In — Web OAuth Client ID
# Get from: Firebase Console → Authentication → Sign-in method
#           → Google → Web SDK configuration → Web client ID
# This is safe to leave empty on Android/iOS (handled by google-services.json)
# ─────────────────────────────────────────────
GOOGLE_SERVER_CLIENT_ID=your_web_oauth_client_id_here.apps.googleusercontent.com

# ─────────────────────────────────────────────
# Public APIs (no keys required — free and open)
# ─────────────────────────────────────────────
JIKAN_BASE_URL=https://api.jikan.moe/v4
ANILIST_BASE_URL=https://graphql.anilist.co
# Consumet API for anime streaming
# Self-host: https://github.com/consumet/api.consumet.org
# OR use public instance (may be slow): https://consumet-api.onrender.com
CONSUMET_BASE_URL=https://consumet-api.onrender.com

# ─────────────────────────────────────────────
# Firebase Crashlytics (optional runtime flags)
# Crashlytics is always disabled in debug mode regardless of these values.
# In release mode it is enabled by default. Set to false to disable.
# ─────────────────────────────────────────────
# ENABLE_CRASHLYTICS=true
# ENABLE_ANALYTICS=true
