# ============================================================
#  AniMatch — .gitignore
# ============================================================

# ─────────────────────────────────────────────
# 🔐 SECURITY — NEVER commit these files
# ─────────────────────────────────────────────
# Firebase secrets (download from Firebase Console and place locally)
google-services.json
GoogleService-Info.plist
# firebase_options.dart is now safe to commit (reads from .env)

# Environment variables
.env
*.env

# Android signing keys — NEVER expose these
*.jks
*.keystore
key.properties
android/key.properties
upload-keystore.jks

# ─────────────────────────────────────────────
# Flutter / Dart
# ─────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Generated files (regenerate with: dart run build_runner build)
*.g.dart
*.freezed.dart

# ─────────────────────────────────────────────
# Hive local database boxes
# ─────────────────────────────────────────────
*.hive
hive_boxes/
**.lock

# ─────────────────────────────────────────────
# Android
# ─────────────────────────────────────────────
/android/app/debug
/android/app/profile
/android/app/release
*.properties
local.properties

# ─────────────────────────────────────────────
# iOS
# ─────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec

# ─────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────
macos/Pods/
macos/.symlinks/

# ─────────────────────────────────────────────
# Build artifacts
# ─────────────────────────────────────────────
app.*.symbols
app.*.map.json

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.suo
*.user

# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
